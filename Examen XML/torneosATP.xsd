<xs:element name = "torneosATP">
	<xs:element name = "fechaIni" type = "xs:date"/>
	<xs:element name = "fechaFin" type = "xs:date"/>
	<xs:element name = "puntosATP">
		<xs:complexType>
			<xs:element name = "ronda" type = "xs:string"/>
				<xs:enumeration value = "2da ronda"/>
				<xs:enumeration value = "3ra ronda"/>
				<xs:enumeration value = "cuartos"/>
				<xs:enumeration value = "semis"/>
				<xs:enumeration value = "finalista"/>
				<xs:enumeration value = "ganador"/>
			</xs:element>
			<xs:element name = "puntos" type = "xs:int"/>
		</xs:complexType>
	<xs:element>
	<xs:elements name = "cuadro">
		<xs:complexType>
			<xs:element name = "cruce">
				<xs:complexType>
					<xs:element name = "jugador">
				</xs:complexType>
			</xs:element>
		</xs:complexType>
	</xs:element>
	<xs:element name = "partidos">
		<xs:complexType>
			<xs:element name= "partido">
				<xs:complexType>
					<xs:element name = "tipo" type = "string">
					<xs:element name = "jugadores">
						<xs:element name = "lado1"></xs:element>
						<xs:element name = "lado2"></xs:element>
					</xs:element>
					<xs:element name = "resultado">
					</xs:element>
				</xs:complexType>
			</xs:element>
		</xs:complexType>
	</xs:element>
</xs:element>